        "Legend and label completeness"
      ]
    },
    "citation_issues": {
      "description": "Citation format checks",
      "checkpoints": [
        "Citation format uniformity",
        "Reference completeness"
      ]
    },
    "experiment_info_gaps": {
      "description": "Experimental information completeness",
      "checkpoints": [
        "Sample size reporting",
        "Replicates reporting",
        "Statistical test specification",
        "Control group description"
      ]
    },
    "language_issues": {
      "description": "Language quality checks",
      "checkpoints": [
        "Article usage",
        "Tense consistency",
        "Plural/singular agreement"
      ]
    }
  },
  
  "review_params_template": {
    "novelty_level": "Original | Incremental | Derivative",
    "academic_impact": "High | Medium | Low",
    "writing_level": "Excellent | Good | Adequate | Poor",
    "reviewer_attitude": "Constructive | Critical | Neutral",
